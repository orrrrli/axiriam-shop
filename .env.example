# ==============================================
# Bean Haven Café - Environment Configuration
# ==============================================

# Demo Mode - Set to 'true' to run without MongoDB
DEMO_MODE=true
NEXT_PUBLIC_DEMO_MODE=true

# ==============================================
# Database Configuration
# ==============================================
# Local MongoDB
MONGODB_URI=mongodb://localhost:27017/bean-haven

# MongoDB Atlas (Production)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/bean-haven?retryWrites=true&w=majority

# ==============================================
# Authentication (NextAuth.js)
# ==============================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# ==============================================
# Payment Processing (Stripe)
# ==============================================
# Get from: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ==============================================
# Email Service (SMTP)
# ==============================================
# Gmail Configuration
EMAIL_SERVER=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-gmail-app-password
EMAIL_FROM=Bean Haven Cafe <noreply@beanhavencafe.com>

# SendGrid Alternative
# EMAIL_SERVER=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USER=apikey
# EMAIL_PASSWORD=your-sendgrid-api-key

# ==============================================
# Optional Services
# ==============================================
# Google Maps API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Admin Configuration
ADMIN_EMAIL=admin@beanhavencafe.com

# ==============================================
# Production Environment Variables
# ==============================================
# For production deployment, ensure:
# 1. DEMO_MODE is set to false
# 2. Use MongoDB Atlas connection string
# 3. Use Stripe live API keys (pk_live_, sk_live_)
# 4. Use a strong NEXTAUTH_SECRET
# 5. Update NEXTAUTH_URL to your domain
# 6. Configure production email service
